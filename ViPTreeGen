#!/usr/bin/env ruby
#
#  ViPTreeGen / a command line tool for viral proteomic tree generation
#
#    Copyright: 2017 (C) Yosuke Nishimura
#    License: MIT
#
#  Entry point. Parses CLI options, validates inputs, checks dependencies,
#  then invokes `rake -f ViPTreeGen.rake` with the resolved options passed via
#  environment variables.
#

STDOUT.sync = true ### real-time output through tee

require "optparse"
require "fileutils"
require "open3"

class ViPTreeGen
  VERSION  = "2.0.0"
  MODIDATE = "2026-05-17"

  ERRMSG = "\e[1;31m[error]\e[0m"
  SCCMSG = "\e[1;32m[success]\e[0m"

  def initialize
    @options = {
      # search engine
      mode:                       "mmseqs-tblastx",
      mmseqs_split_memory_limit:  "12G",
      mmseqs_tblastx_chunk_size:  1000,

      # tblastx / mmseqs shared
      cutlen:  100_000,
      dbsize:  "200000000",
      matrix:  "BLOSUM45",
      evalue:  "1e-2",
      idt:     30,
      aalen:   30,

      # tree
      notree:  false,
      method:  "bionj",

      # 2D
      twoD:    nil,

      # with-reference mode (--ref-duckdb path/to/previous-run.duckdb)
      ref_duckdb: nil,

      # computation
      ncpus:   nil,
      queue:   nil,
      wtime:   "24:00:00",

      # resume a previously-failed run (output dir must already exist)
      resume:  false,
    }

    @progname  = File.basename($0)
    @scrdir    = File.dirname(File.expand_path($0))
    @stime     = Time.now
    @stime_str = @stime.strftime("%Y-%m-%d %H:%M:%S")
    @incmd     = "#{$0} #{ARGV.join(" ")}"
  end

  # {{{ def usage
  def usage
    <<~EOF
    \e[1;35m### #{@progname} ver #{VERSION} (#{MODIDATE}) ###\e[0m

    \e[1;32m[description]\e[0m
    #{@progname} - tool for viral proteomic tree generation from viral genomic sequences.
    #{@progname} has been developed as the ViPTree server project (http://www.genome.jp/viptree).

    #{@progname} first computes genome-wide sequence similarity distance based on tBLASTx results,
    then construct (bio)nj tree based on the distance (1 - similarity) matrix.

    Complete genomes are recommended as input sequence for accurate distance/tree computation,
    though genome fragments are also acceptable.

    If you compute many sequences (e.g. n > 100) or large sequences (e.g. NCLDV genomes), it may take a long time.
    In those cases, use '--ncpus' or '--queue' for parallel computating.

    \e[1;32m[usage]\e[0m
    $ #{@progname} [options] <input fasta> <output dir>

    - <input fasta> should be in nucleotide FASTA format and include at least 3 sequences.
    - If sequence name (before the first space in the header line) includes a character other than
      alphabets, numbers, dot(.), hyphen(-), or underscore(_), it will be replaced with underscore.
    - <output dir> should not exist.

    \e[1;32m[dependencies]\e[0m
        - mmseqs2 (>=13.45111)    -- MMseqs2 (required for --mode mmseqs-tblastx, the default);
                                     https://github.com/soedinglab/MMseqs2
        - tblastx / blastn        -- in NCBI BLAST+ (required for --mode tblastx or --mode blastn);
                                     https://blast.ncbi.nlm.nih.gov/Blast.cgi?PAGE_TYPE=BlastDocs&DOC_TYPE=Download
        - ruby (ver >=2.0)        -- orchestration; tested with 2.x/3.x/4.x
        - duckdb (>=1.0)          -- CLI; used to aggregate run state into ${outdir}/run.duckdb
        - viptreegen-summary-pre  -- bundled Rust binary; replaces the 01-3/02-1/02-2/02-3 Ruby+SQL path (new in v2.0.0).
                                     Installed by Bioconda. For source builds, run 'cargo build --release --manifest-path rust/Cargo.toml'.

      (for tree generation)
        - R (ver >=3.0)
        - R package 'ape'      -- try install.packages('ape') in R terminal
        - R package 'phangorn' -- try install.packages('phangorn') in R terminal

    \e[1;32m[options]\e[0m
      (general)
        -h, --help
        -v, --version

      (search engine)
        --mode  [mmseqs-tblastx|tblastx|blastn] (default: mmseqs-tblastx)
                                                           -- search engine x algorithm.
                                                              'mmseqs-tblastx' (default) : MMseqs2 --search-type 4,
                                                                                           translated 6-frame; proteomic
                                                                                           tree (ViPTree); ~10x faster
                                                                                           than tblastx.
                                                              'tblastx'                  : NCBI BLAST+ tblastx, translated
                                                                                           6-frame; proteomic tree
                                                                                           (byte-exact pre-v2.0 reproduction).
                                                              'blastn'                   : NCBI BLAST+ blastn, nucleotide-vs-
                                                                                           nucleotide; nucleotide tree
                                                                                           (DiGAlign backend).

                                                              ('mmseqs-blastn' was evaluated and removed -- see
                                                              doc/mmseqs-blastn.md for the slow/insensitive findings.)
        --mmseqs-tblastx-chunk-size [int]  (default: 1000)  -- split query fasta into N-sequence chunks
                                                              and run mmseqs search per chunk so that --resume
                                                              can pick up between chunks (each chunk records a
                                                              step_done marker in run_metadata). 0 disables
                                                              chunking (one global search). mmseqs-tblastx mode only.
        --mmseqs-split-memory-limit [size] (default: 12G)   -- peak RAM cap for mmseqs target index (e.g. 12G, 4G).
                                                              Pass through to mmseqs --split-memory-limit. Use a smaller
                                                              value on a memory-constrained host (slower but bounded).
                                                              Pass '0' (= mmseqs default) to disable the cap and let
                                                              mmseqs use as much RAM as needed (fastest, unbounded).
                                                              mmseqs mode only.

      (tblastx / mmseqs shared)
        --cutlen       [>=10000]   (default: 100000)    -- length to split input sequences for faster computation
        --dbsize       [int]       (default: 200000000) -- ignored in --mode mmseqs-tblastx (no equivalent knob)
        --matrix       [str]       (default: BLOSUM45)
        --evalue       [num]       (default: 1e-2)
        --min-idt      [int]       (default: 30)
        --min-aalen    [int]       (default: 30)

      (tree)
        --notree                   (default: off)       -- generate only similarity/distance matrix
        --method       [nj|bionj]  (default: bionj)     -- proteomic tree generation method

      (2D mode)
        --2D           [query fasta] (default: off)     -- do not generate tree but similarity matrix of: 'query sequences' against 'input sequences'. 2D mode is designed to find the most related 'input sequence' for each 'query sequence'

      (with-reference mode)
        --ref-duckdb   [path/run.duckdb]                -- a previous ViPTreeGen run.duckdb that supplies the reference set.
                                                           ref sequences, ref self_scores, and ref-vs-ref summary_tsv are
                                                           imported from it; input is searched against (input ∪ ref) so that
                                                           input-vs-ref pairs are computed but ref-vs-ref pairs are NOT
                                                           recomputed. Output is the combined sim/dist matrix and tree over
                                                           (ref ∪ input). Requires schema_version >= 2.0 (i.e., reference
                                                           was generated with ViPTreeGen v2.0+). Mutually exclusive with --2D.

      (use GNU parallel)
        --ncpus        [int]                            -- number of jobs in parallel

      (for icr user)                                    -- for computation in the ICR supercomputer system
        --queue        [JP1]                            -- queue for computation

    \e[1;32m[output files]\e[0m
      (normal mode)
        result/all.sim.matrix              -- similarity (SG score) matrix
        result/all.dist.matrix             -- distance (1-SG score) matrix
        result/all.[bio]nj.[a|de]sc.newick -- Newick files of the viral proteomic tree, midpoint rooted and ladderized

      (2D mode)
        result/2D.sim.matrix               -- similarity (SG score) matrix (row-wise: query fasta, column-wise: input fasta)
        result/top10.sim.list              -- top10 SG scores for each query sequence. format: 1st column - query ID; from 2nd to 11st columns - ID:SG_score

      (aggregated state)
        run.duckdb                         -- single DuckDB file: summary_pre (per-pair raw stats), self_scores, summary_tsv,
                                              sequences, run_metadata, logs (tblastx + makeblastdb).
                                              Inspect with `duckdb run.duckdb`. Per-node tblastx.out files are deleted after the
                                              Rust binary (viptreegen-summary-pre) consumes them into summary_pre.
    EOF
  end
  # }}} def usage

  # {{{ def parse_options
  def parse_options
    parser = OptionParser.new do |opts|
      opts.banner = usage

      ## search engine
      opts.on("--mode MODE",
              "search engine x algorithm. proteomic-tree: tblastx|mmseqs-tblastx. " \
              "nucleotide-tree (DiGAlign backend): blastn. (default: mmseqs-tblastx)") do |v|
        @options[:mode] = v
      end
      opts.on("--mmseqs-split-memory-limit SIZE",
              "mmseqs --split-memory-limit (default: 12G; pass 0 to disable)") do |v|
        @options[:mmseqs_split_memory_limit] = v
      end
      opts.on("--mmseqs-tblastx-chunk-size INT", Integer,
              "split the query fasta into N-sequence chunks for mmseqs-tblastx so that " \
              "--resume can pick up between chunks (default: 1000; pass 0 to disable and " \
              "run one global mmseqs search). mmseqs-tblastx mode only.") do |v|
        @options[:mmseqs_tblastx_chunk_size] = v
      end

      ## tblastx / mmseqs shared
      opts.on("--cutlen INT", Integer)      { |v| @options[:cutlen] = v }
      opts.on("--dbsize INT")               { |v| @options[:dbsize] = v }
      opts.on("--matrix STR")               { |v| @options[:matrix] = v }
      opts.on("--evalue NUM")               { |v| @options[:evalue] = v }
      opts.on("--min-idt INT", Integer)     { |v| @options[:idt] = v }
      opts.on("--min-aalen INT", Integer)   { |v| @options[:aalen] = v }

      ## tree
      opts.on("--notree")                   { @options[:notree] = true }
      opts.on("--method METHOD",
              "tree method: nj or bionj (default: bionj)") { |v| @options[:method] = v }

      ## 2D mode
      opts.on("--2D FASTA",
              "query fasta for 2D mode (similarity matrix of query x input)") { |v| @options[:twoD] = v }

      ## with-reference mode
      opts.on("--ref-duckdb DBFILE",
              "previous ViPTreeGen run.duckdb (provides ref sequences, self_scores, and ref-vs-ref summary_tsv; " \
              "input is searched against (input ∪ ref), ref-vs-ref pairs are not recomputed)") { |v| @options[:ref_duckdb] = v }

      ## computation
      opts.on("--ncpus INT")                { |v| @options[:ncpus] = v }
      opts.on("--queue QUEUE")              { |v| @options[:queue] = v }
      opts.on("--wtime TIME")               { |v| @options[:wtime] = v }

      ## resume a previously-interrupted run
      opts.on("--resume",
              "resume from the last completed pipeline step. <output dir> must exist " \
              "and contain run.duckdb from the prior run; <input fasta> is ignored at " \
              "runtime (the input is read from cat/all/all.fasta in the existing dir)") {
        @options[:resume] = true
      }

      ## general
      opts.on("-h", "--help")    { puts usage; exit 0 }
      opts.on("-v", "--version") { puts VERSION; exit 0 }
    end

    begin
      parser.parse!
    rescue OptionParser::InvalidOption, OptionParser::InvalidArgument, OptionParser::MissingArgument => e
      $stderr.puts "#{ERRMSG} #{e.message}"
      $stderr.puts "         execute '#{@progname} -h' for usage"
      exit 1
    end

    if ARGV.size != 2
      $stderr.puts "#{ERRMSG} require <input fasta> and <output dir> after options (got #{ARGV.size} positional)"
      $stderr.puts "         execute '#{@progname} -h' for usage"
      exit 1
    end
    @fin = ARGV[0]
    @dir = ARGV[1]
  end
  # }}} def parse_options

  # {{{ def validate_options
  def validate_options
    if @options[:resume]
      ## --resume inverts the dir-exists check: dir must already exist with a run.duckdb.
      ## <fin> is required syntactically (positional CLI shape) but ignored at runtime.
      unless File.directory?(@dir)
        $stderr.puts "#{ERRMSG} --resume requires an existing output directory (not found: #{@dir})"
        exit 1
      end
      unless File.file?(File.join(@dir, "run.duckdb"))
        $stderr.puts "#{ERRMSG} --resume requires #{@dir}/run.duckdb from the previous run"
        exit 1
      end
    else
      unless File.file?(@fin)
        $stderr.puts "#{ERRMSG} first argument should be a fasta file (not found: #{@fin})"
        exit 1
      end
      if File.exist?(@dir)
        $stderr.puts "#{ERRMSG} output directory already exists (#{@dir}) -- use --resume to continue, or pick a fresh dir"
        exit 1
      end
    end
    valid_modes = %w[tblastx mmseqs-tblastx blastn]
    unless valid_modes.include?(@options[:mode])
      $stderr.puts "#{ERRMSG} --mode must be one of #{valid_modes.join(', ')} (got: '#{@options[:mode]}')"
      exit 1
    end
    if @options[:twoD] && !File.file?(@options[:twoD])
      $stderr.puts "#{ERRMSG} --2D fasta not found: #{@options[:twoD]}"
      exit 1
    end
    if @options[:ref_duckdb]
      if @options[:twoD]
        $stderr.puts "#{ERRMSG} --ref-duckdb and --2D are mutually exclusive"
        exit 1
      end
      unless File.file?(@options[:ref_duckdb])
        $stderr.puts "#{ERRMSG} --ref-duckdb file not found: #{@options[:ref_duckdb]}"
        exit 1
      end
    end
  end
  # }}} def validate_options

  # {{{ def check_dependencies
  def check_dependencies
    case @options[:mode]
    when "tblastx"
      check_cmd("tblastx",     "in BLAST+ package; required for --mode tblastx")
      check_cmd("makeblastdb", "in BLAST+ package; required for --mode tblastx")
    when "blastn"
      check_cmd("blastn",      "in BLAST+ package; required for --mode blastn (DiGAlign backend)")
      check_cmd("makeblastdb", "in BLAST+ package; required for --mode blastn")
    when "mmseqs-tblastx"
      check_cmd("mmseqs",      "MMseqs2; required for --mode mmseqs-tblastx")
    end

    unless @options[:notree]
      check_cmd("R", "required for tree generation (or pass --notree)")
      check_r_pkg("ape")
      check_r_pkg("phangorn")
    end

    if Gem::Version.new(RUBY_VERSION) < Gem::Version.new("2.0.0")
      $stderr.puts "#{ERRMSG} ruby (version >=2.0) is required"
      exit 1
    end

    check_cmd("duckdb", "CLI used to aggregate run state into run.duckdb")

    unless ENV["VIPTREEGEN_SUMMARY_PRE"] ||
           system("command -v viptreegen-summary-pre >/dev/null 2>&1") ||
           File.executable?(File.join(@scrdir, "rust/target/release/viptreegen-summary-pre"))
      $stderr.puts "#{ERRMSG} viptreegen-summary-pre (bundled Rust binary) is required but not available."
      $stderr.puts "         Install via Bioconda, or build from source:"
      $stderr.puts "         cargo build --release --manifest-path #{@scrdir}/rust/Cargo.toml"
      exit 1
    end

    check_cmd("parallel", "GNU parallel; required when --ncpus is set") if @options[:ncpus]
  end

  def check_cmd(cmd, hint)
    unless system("command -v #{cmd} >/dev/null 2>&1")
      $stderr.puts "#{ERRMSG} #{cmd} is required but not available (#{hint}). Aborting."
      exit 1
    end
  end

  def check_r_pkg(pkg)
    _, status = Open3.capture2e("LANG=C R --quiet --no-save --no-restore -e \"library('#{pkg}')\"")
    unless status.success?
      $stderr.puts "#{ERRMSG} R package '#{pkg}' must be installed but not available. Aborting."
      exit 1
    end
  end
  # }}} def check_dependencies

  # {{{ def setup_logging
  def setup_logging
    @logdir  = File.join(@dir, "log")
    FileUtils.mkdir_p(@logdir)
    @logfile = File.join(@logdir, "#{@progname}.log")

    incmdlog = <<~EOF

    \e[1;32m===== command line\e[0m

    $ #{@incmd}

    \e[1;32m===== log file\e[0m

    #{@logfile}

    \e[1;32m===== check version: #{@progname}\e[0m

    #{VERSION}

    EOF
    File.open(@logfile, "a") { |f| f.write(incmdlog) }
    puts incmdlog
  end
  # }}} def setup_logging

  # {{{ def run_rake
  def run_rake
    rakefile = File.join(@scrdir, "#{@progname}.rake")
    env_vars = {
      "dir"                       => @dir,
      "fin"                       => @fin,
      "cutlen"                    => @options[:cutlen].to_s,
      "dbsize"                    => @options[:dbsize].to_s,
      "matrix"                    => @options[:matrix],
      "evalue"                    => @options[:evalue].to_s,
      "idt"                       => @options[:idt].to_s,
      "aalen"                     => @options[:aalen].to_s,
      "mode"                      => @options[:mode],
      "mmseqs_split_memory_limit" => @options[:mmseqs_split_memory_limit],
      "mmseqs_tblastx_chunk_size" => @options[:mmseqs_tblastx_chunk_size].to_s,
      "twoD"                      => @options[:twoD].to_s,
      "ref_duckdb"                => @options[:ref_duckdb].to_s,
      "resume"                    => @options[:resume] ? "true" : "",
      "method"                    => @options[:method],
      "queue"                     => @options[:queue].to_s,
      "ncpus"                     => @options[:ncpus].to_s,
      "wtime"                     => @options[:wtime],
      "notree"                    => @options[:notree] ? "true" : "",
    }
    env_vars.each { |k, v| ENV[k] = v }

    %w[HUP INT QUIT TERM].each do |sig|
      Signal.trap(sig) { after_run(1); exit 1 }
    end

    status = 1
    File.open(@logfile, "a") do |fw|
      fw.sync = true
      Open3.popen2e("rake", "-f", rakefile) do |stdin, out, wait_thr|
        stdin.close
        out.each_line do |line|
          fw.write(line)
          STDOUT.write(line)
        end
        status = wait_thr.value.exitstatus
      end
    end
    after_run(status)
    exit status
  end
  # }}} def run_rake

  # {{{ def after_run
  def after_run(status)
    etime = Time.now.strftime("%Y-%m-%d %H:%M:%S %z")
    if status == 0
      File.open(File.join(@logdir, "#{@stime_str}.#{@progname}.success"), "w") do |f|
        f.puts "#{SCCMSG} run finished: #{etime}"
      end
    else
      File.open(File.join(@logdir, "#{@stime_str}.#{@progname}.error"), "w") do |f|
        f.puts "#{ERRMSG} run failed: #{etime}"
      end
      msg = "#{ERRMSG} process is killed: #{etime}"
      $stderr.puts msg
      File.open(@logfile, "a") { |f| f.puts msg } if @logfile && File.exist?(@logfile)
    end
  end
  # }}} def after_run

  # {{{ def run
  def run
    parse_options
    validate_options
    check_dependencies
    setup_logging
    run_rake
  end
  # }}} def run
end

if __FILE__ == $0
  require "rubygems"
  ViPTreeGen.new.run
end
